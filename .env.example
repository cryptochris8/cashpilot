# ============================================================================
# CashPilot - Environment Variables
# ============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For production, set these in your Vercel project settings:
#   https://vercel.com/your-team/cashpilot/settings/environment-variables
# ============================================================================

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------

# The canonical URL of your deployed app (no trailing slash)
# Local: http://localhost:3000  |  Production: https://cashpilot.yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# "development" | "production" | "test"
NODE_ENV=development

# ----------------------------------------------------------------------------
# Clerk (Authentication)
# https://dashboard.clerk.com  ->  API Keys
# ----------------------------------------------------------------------------

# Publishable key (safe to expose to the browser)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Secret key (server-side only)
CLERK_SECRET_KEY=sk_test_...

# Redirect paths used by Clerk components and middleware
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup

# Webhook signing secret for Clerk -> your app events (user.created, etc.)
# Found in Clerk Dashboard -> Webhooks -> Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...

# ----------------------------------------------------------------------------
# Neon (Serverless Postgres)
# https://console.neon.tech  ->  Connection Details
# ----------------------------------------------------------------------------

# Pooled connection string (used at runtime by Prisma Client)
# Format: postgresql://user:password@ep-xxx-pooler-123456.region.aws.neon.tech/dbname?sslmode=require
# Use the "Pooled connection" string from Neon dashboard (hostname contains "-pooler")
DATABASE_URL=postgresql://user:password@ep-example-pooler-123456.us-east-2.aws.neon.tech/cashpilot?sslmode=require

# Direct (non-pooled) connection string (used for running migrations)
# Format: postgresql://user:password@ep-xxx-123456.region.aws.neon.tech/dbname?sslmode=require
# Use the "Direct connection" string from Neon dashboard (hostname has no "-pooler")
DIRECT_DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/cashpilot?sslmode=require

# ----------------------------------------------------------------------------
# Stripe (Billing & Payments)
# https://dashboard.stripe.com/apikeys
# ----------------------------------------------------------------------------

# Publishable key (safe to expose to the browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Secret key (server-side only)
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret for Stripe -> your app events
# Found in Stripe Dashboard -> Developers -> Webhooks -> Signing secret
# Or via CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs for subscription plans (create in Stripe Dashboard -> Products)
# Starter plan: $29/month with 14-day free trial
STRIPE_PRICE_STARTER=price_...

# Growth plan: $79/month with 14-day free trial
STRIPE_PRICE_GROWTH=price_...

# ----------------------------------------------------------------------------
# Resend (Transactional Email)
# https://resend.com/api-keys
# ----------------------------------------------------------------------------

# API key for sending emails (daily reminders, notifications)
RESEND_API_KEY=re_...

# "From" address for outgoing emails (must be on a verified Resend domain)
# The app defaults to "CashPilot <reminders@cashpilot.app>" if not overridden.
# Example: CashPilot <notifications@cashpilot.com>
EMAIL_FROM=CashPilot <reminders@cashpilot.app>

# ----------------------------------------------------------------------------
# Inngest (Background Jobs & Cron)
# https://app.inngest.com  ->  Manage -> Signing Key / Event Key
# ----------------------------------------------------------------------------

# Event key (used to send events from your app to Inngest)
INNGEST_EVENT_KEY=

# Signing key (used by Inngest to verify requests to your /api/inngest endpoint)
INNGEST_SIGNING_KEY=signkey-...

# ----------------------------------------------------------------------------
# QuickBooks Online (Accounting Integration via OAuth 2.0)
# https://developer.intuit.com  ->  My Apps -> Keys & OAuth
# ----------------------------------------------------------------------------

# OAuth 2.0 Client ID
QBO_CLIENT_ID=

# OAuth 2.0 Client Secret
QBO_CLIENT_SECRET=

# OAuth redirect URI -- must match exactly what is registered in Intuit Developer portal
# Local: http://localhost:3000/api/qbo/callback
# Production: https://cashpilot.yourdomain.com/api/qbo/callback
QBO_REDIRECT_URI=http://localhost:3000/api/qbo/callback

# "sandbox" for development/testing, "production" for live QuickBooks data
QBO_ENVIRONMENT=sandbox

# AES-256 encryption key for encrypting/decrypting stored OAuth tokens at rest
# Generate with:  openssl rand -base64 32
# IMPORTANT: Once set, do NOT rotate this key or all stored tokens become unreadable
QBO_TOKEN_ENCRYPTION_KEY=

# ----------------------------------------------------------------------------
# Sentry (Error Monitoring & Performance)
# https://sentry.io  ->  Settings -> Projects -> Client Keys (DSN)
# ----------------------------------------------------------------------------

# Data Source Name -- identifies your project in Sentry (safe to expose client-side)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Auth token for source map uploads during build (CI/CD only)
# https://sentry.io  ->  Settings -> Auth Tokens
SENTRY_AUTH_TOKEN=sntrys_...
